# Klaro AI API Configuration
# Copy this file to .env and fill in your API keys

# ==========================================
# REQUIRED API KEYS
# ==========================================

# Google Gemini AI API Key
# Get your FREE key from: https://aistudio.google.com/
# Used for primary AI summarization and analysis
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Key
# Get your FREE key from: https://openrouter.ai/
# Used for multi-model AI fallback system
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ElevenLabs Text-to-Speech API Key
# Get your FREE key from: https://elevenlabs.io/
# Used for natural voice read-along functionality
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ==========================================
# OPTIONAL CONFIGURATION
# ==========================================

# AI Model Selection
# Primary Gemini model (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# Primary OpenRouter model (default: google/gemma-4-26b-a4b-it:free)
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# ==========================================
# SERVER CONFIGURATION
# ==========================================

# Port for the API server
# Cloud Run automatically sets PORT=8080; locally defaults to 3001
PORT=3001

# Frontend origin for CORS (comma-separated for multiple origins)
# Local development:
FRONTEND_ORIGIN=http://localhost:5173
# Production example (update after deploying frontend):
# FRONTEND_ORIGIN=https://your-klaro-ai-frontend.web.app,http://localhost:5173